rules_version = '2';

// ─── RÈGLES DE SÉCURITÉ FIRESTORE ────────────────────────────────────────────
// Principe : chaque utilisateur ne peut lire et écrire QUE son propre document.
// À déployer via : firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Document utilisateur : lecture/écriture autorisées uniquement au propriétaire
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Validation optionnelle des champs à l'écriture
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly([
                        'name', 'email', 'createdAt', 'updatedAt',
                        'xp', 'streak', 'lastActivityDate', 'departments'
                      ]);
    }

    // Tout autre document : accès refusé par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
